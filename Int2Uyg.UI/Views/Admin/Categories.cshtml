@{
    ViewData["Title"] = "Anket Kategorileri";
}

<div class="row">
    <div class="col-md-8" id="listArea">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-primary text-white">
                <h6 class="m-0 font-weight-bold"><i class="fas fa-folder mr-2"></i>Sistemdeki Kategoriler</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="tbCategoryList" width="100%" cellspacing="0">
                        <thead>
                            <tr class="bg-light text-dark">
                                <th>Kategori Adı</th>
                                <th>Açıklama</th>
                                <th>Anket Sayısı</th>
                                <th>Durumu</th>
                                <th id="thActions" style="width: 100px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4" id="formArea">
        <div class="card shadow mb-4 border-left-primary">
            <div class="card-header py-3 bg-white text-primary">
                <h6 class="m-0 font-weight-bold" id="formTitle">Yeni Kategori Ekle</h6>
            </div>
            <div class="card-body">
                <form id="frmCategory">
                    <input type="hidden" id="txtId" />

                    <div class="form-group">
                        <label class="font-weight-bold text-dark small">Kategori Adı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtName" placeholder="Örn: İnsan Kaynakları" required>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold text-dark small">Açıklama</label>
                        <textarea class="form-control" id="txtDescription" rows="2"
                                  placeholder="Kategori hakkında kısa bir açıklama yazın..."></textarea>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-checkbox small">
                            <input type="checkbox" class="custom-control-input" id="cbIsActive" checked>
                            <label class="custom-control-label" for="cbIsActive">Kategori Yayında mı?</label>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="button" class="btn btn-primary btn-block shadow-sm font-weight-bold" id="btnSave">
                            <i class="fa fa-save mr-1"></i> Kaydet
                        </button>
                        <div id="editButtons" style="display:none;">
                            <button type="button" class="btn btn-warning btn-block shadow-sm font-weight-bold" id="btnUpdate">
                                <i class="fa fa-edit mr-1"></i> Güncelle
                            </button>
                            <button type="button" class="btn btn-danger btn-block shadow-sm font-weight-bold" id="btnDelete">
                                <i class="fa fa-trash mr-1"></i> Sil
                            </button>
                            <button type="button" class="btn btn-secondary btn-block shadow-sm font-weight-bold" id="btnCancel">
                                <i class="fa fa-times mr-1"></i> Vazgeç
                            </button>
                        </div>
                    </div>
                </form>
                <div id="divResult" class="mt-3" style="display:none;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var apiBaseUrl = "https://localhost:7258/api";
            var token = localStorage.getItem("token");

            if (!token) { window.location.href = "/Login"; return; }

            function parseJwtSafe(token) {
                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join(''));
                    return JSON.parse(jsonPayload);
                } catch (e) { return null; }
            }

            var payload = parseJwtSafe(token);
            var roles = payload ? payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] : null;
            var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));

            if (!isAdmin) {
                $("#formArea").remove();
                $("#listArea").removeClass("col-md-8").addClass("col-md-12");
                $("#thActions").hide();
            }

            GetCategoryList();

            function GetCategoryList() {
                $.ajax({
                    url: apiBaseUrl + "/Category/List",
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        var row = "";
                        $("#tbCategoryList tbody").empty();

                        $.each(data, function (i, item) {
                            var name = item.name || "";
                            var description = (item.description || "—");
                            var shortDesc = description.length > 50
                                ? description.substring(0, 47) + "..."
                                : description;

                            var statusBadge = item.isActive ?
                                '<span class="badge badge-success">Yayında</span>' :
                                '<span class="badge badge-danger">Pasif</span>';

                            row += "<tr>";
                            row += "<td class='font-weight-bold text-dark'>" + toTitleCase(name) + "</td>";
                            row += "<td class='text-muted small'>" + shortDesc + "</td>";
                            row += "<td>" + (item.surveyCount || 0) + " Anket</td>";
                            row += "<td>" + statusBadge + "</td>";

                            if (isAdmin) {
                                row += '<td><button class="btn btn-info btn-sm btnEdit" data-id="' + item.id + '">' +
                                       '<i class="fa fa-edit"></i> Düzenle</button></td>';
                            }
                            row += "</tr>";
                        });
                        $("#tbCategoryList tbody").append(row);
                    },
                    error: function(xhr, status, error) {
                        console.error("Kategori listesi yüklenemedi:", error);
                        $("#tbCategoryList tbody").html(
                            '<tr><td colspan="5" class="text-center text-danger">' +
                            'Kategoriler yüklenirken bir hata oluştu.</td></tr>'
                        );
                    }
                });
            }

            $("#btnSave").click(function () {
                var name = $("#txtName").val().trim();
                var description = $("#txtDescription").val().trim();

                if (!name) {
                    showResult("Lütfen kategori adı giriniz!", "warning");
                    $("#txtName").focus();
                    return;
                }

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Kaydediliyor...');

                var categoryData = {
                    name: name,
                    description: description || "Açıklama belirtilmedi",
                    isActive: $("#cbIsActive").is(":checked")
                };

                $.ajax({
                    url: apiBaseUrl + "/Category/Add",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(categoryData),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fa fa-save mr-1"></i> Kaydet');

                        var success = d.status !== undefined ? d.status : d.Status;
                        var message = d.message !== undefined ? d.message : d.Message;

                        if (success) {
                            showResult(message || "Kategori başarıyla eklendi!", "success");
                            ResetForm();
                            GetCategoryList();
                        } else {
                            showResult(message || "Kategori eklenemedi.", "danger");
                        }
                    },
                    error: function(xhr) {
                        btn.prop("disabled", false).html('<i class="fa fa-save mr-1"></i> Kaydet');
                        var errorMsg = "Bağlantı Hatası";
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        } else if (xhr.responseJSON && xhr.responseJSON.Message) {
                            errorMsg = xhr.responseJSON.Message;
                        }
                        showResult(errorMsg + " (Hata: " + xhr.status + ")", "danger");
                    }
                });
            });

            $(document).on("click", ".btnEdit", function () {
                var id = $(this).data("id");

                var btn = $(this);
                var originalHtml = btn.html();
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i>');

                $.ajax({
                    url: apiBaseUrl + "/Category/GetById/" + id,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (d) {
                        $("#txtId").val(d.id);
                        $("#txtName").val(d.name || "");
                        $("#txtDescription").val(d.description || "");
                        $("#cbIsActive").prop("checked", d.isActive !== undefined ? d.isActive : true);

                        $("#btnSave").hide();
                        $("#editButtons").show();
                        $("#formTitle").text("Kategoriyi Düzenle");

                        btn.prop("disabled", false).html(originalHtml);
                    },
                    error: function() {
                        showResult("Kategori bilgisi alınamadı.", "danger");
                        btn.prop("disabled", false).html(originalHtml);
                    }
                });
            });


            $("#btnUpdate").click(function () {
                var rawId = $("#txtId").val();
                var name = $("#txtName").val().trim();
                var description = $("#txtDescription").val().trim();

                if (!rawId) {
                    showResult("Düzenlenecek kategori bulunamadı!", "danger");
                    return;
                }

                if (!name) {
                    showResult("Kategori adı boş olamaz!", "warning");
                    $("#txtName").focus();
                    return;
                }

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Güncelleniyor...');

                var categoryData = {
                    id: parseInt(rawId),
                    name: name,
                    description: description || "Açıklama belirtilmedi",
                    isActive: $("#cbIsActive").is(":checked")
                };

                $.ajax({
                    url: apiBaseUrl + "/Category/Update",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(categoryData),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fa fa-edit mr-1"></i> Güncelle');

                        var success = d.status !== undefined ? d.status : d.Status;
                        var message = d.message !== undefined ? d.message : d.Message;

                        if (success) {
                            showResult(message || "Kategori başarıyla güncellendi!", "success");
                            ResetForm();
                            GetCategoryList();
                        } else {
                            showResult(message || "Kategori güncellenemedi.", "danger");
                        }
                    },
                    error: function(xhr) {
                        btn.prop("disabled", false).html('<i class="fa fa-edit mr-1"></i> Güncelle');
                        var errorMsg = "Güncelleme sırasında hata oluştu";
                        if (xhr.responseJSON && (xhr.responseJSON.message || xhr.responseJSON.Message)) {
                            errorMsg = xhr.responseJSON.message || xhr.responseJSON.Message;
                        }
                        showResult(errorMsg + " (Hata: " + xhr.status + ")", "danger");
                    }
                });
            });

            $("#btnDelete").click(function () {
                var id = parseInt($("#txtId").val());
                if (!id) {
                    showResult("Silinecek kategori bulunamadı!", "danger");
                    return;
                }

                if(confirm("Bu kategoriyi silmek istediğinize emin misiniz?\n\n" +
                          "Uyarı: Üzerinde anket bulunan kategoriler silinemez.")) {

                    var btn = $(this);
                    btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Siliniyor...');

                    $.ajax({
                        url: apiBaseUrl + "/Category/Delete/" + id,
                        type: "DELETE",
                        headers: { "Authorization": "Bearer " + token },
                        success: function (d) {
                            btn.prop("disabled", false).html('<i class="fa fa-trash mr-1"></i> Sil');

                            var success = d.status !== undefined ? d.status : d.Status;
                            var message = d.message !== undefined ? d.message : d.Message;

                            if (success) {
                                showResult(message || "Kategori başarıyla silindi!", "success");
                                ResetForm();
                                GetCategoryList();
                            } else {
                                showResult(message || "Kategori silinemedi.", "warning");
                            }
                        },
                        error: function(xhr) {
                            btn.prop("disabled", false).html('<i class="fa fa-trash mr-1"></i> Sil');
                            var errorMsg = "Silme işlemi başarısız";
                            if (xhr.responseJSON && (xhr.responseJSON.message || xhr.responseJSON.Message)) {
                                errorMsg = xhr.responseJSON.message || xhr.responseJSON.Message;
                            }
                            showResult(errorMsg + " (Hata: " + xhr.status + ")", "danger");
                        }
                    });
                }
            });

            function ResetForm() {
                $("#frmCategory")[0].reset();
                $("#txtId").val("");
                $("#txtDescription").val("");
                $("#btnSave").show();
                $("#editButtons").hide();
                $("#formTitle").text("Yeni Kategori Ekle");
            }

            $("#btnCancel").click(function () {
                ResetForm();
                $("#divResult").fadeOut(300);
            });

            function showResult(message, type) {
                $("#divResult").stop(true, true).hide()
                    .removeClass().addClass("alert alert-" + type + " shadow-sm")
                    .html('<i class="fas fa-info-circle mr-2"></i>' + message).fadeIn(500);

                var timeout = (type === "success") ? 3000 : 6000;
                setTimeout(function() { $("#divResult").fadeOut(1000); }, timeout);
            }

            function toTitleCase(str) {
                if(!str) return "";
                return str.split(' ').map(function(word) {
                    return word.charAt(0).toLocaleUpperCase('tr-TR') + word.slice(1).toLocaleLowerCase('tr-TR');
                }).join(' ');
            }
        });
    </script>
}