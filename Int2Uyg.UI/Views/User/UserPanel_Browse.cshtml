@{
    ViewData["Title"] = "Anketleri Keşfet";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    .filter-bar {
        background: white;
        border-radius: 16px;
        padding: 1rem 1.5rem;
        box-shadow: 0 4px 24px rgba(108,99,255,0.07);
        border: 1px solid rgba(108,99,255,0.06);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

        .filter-bar input {
            border: 1.5px solid rgba(108,99,255,0.2);
            border-radius: 10px;
            padding: 8px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            flex: 1;
            min-width: 200px;
            outline: none;
            transition: border-color 0.2s;
        }

            .filter-bar input:focus {
                border-color: #6c63ff;
            }

    .category-pills {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .cat-pill {
        background: white;
        border: 1.5px solid rgba(108,99,255,0.2);
        border-radius: 50px;
        padding: 6px 16px;
        font-size: 0.8rem;
        font-weight: 600;
        font-family: 'Sora', sans-serif;
        color: #6b7280;
        cursor: pointer;
        transition: all 0.2s;
    }

        .cat-pill:hover, .cat-pill.active {
            background: #6c63ff;
            border-color: #6c63ff;
            color: white;
        }

    .survey-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1rem;
    }

    .survey-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(108,99,255,0.07);
        border: 1px solid rgba(108,99,255,0.06);
        transition: all 0.2s;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .survey-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(108,99,255,0.15);
            color: inherit;
        }

    .survey-card-img {
        width: 100%;
        height: 130px;
        object-fit: cover;
    }

    .survey-card-img-placeholder {
        width: 100%;
        height: 130px;
        background: linear-gradient(135deg, #ede9ff, #fce4ec);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .survey-card-body {
        padding: 1rem 1.25rem;
    }

    .survey-card-title {
        font-family: 'Sora', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 4px;
    }

    .survey-card-cat {
        font-size: 0.75rem;
        color: #6b7280;
        margin-bottom: 0.75rem;
    }

    .survey-card-footer {
        padding: 0.6rem 1.25rem;
        border-top: 1px solid rgba(108,99,255,0.06);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .take-btn {
        font-family: 'Sora', sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        color: #6c63ff;
        text-decoration: none;
    }

        .take-btn:hover {
            color: #5a52d5;
        }

    .empty-state {
        grid-column: 1/-1;
        text-align: center;
        padding: 3rem;
        color: #6b7280;
    }

        .empty-state i {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
            opacity: 0.4;
        }

    .result-count {
        font-size: 0.85rem;
        color: #6b7280;
        margin-bottom: 1rem;
    }
</style>

<!-- Page header -->
<div class="page-header-user">
    <h1>Anketleri Keşfet</h1>
    <p>Kategorilere göre filtrele, ilgini çeken ankete katıl.</p>
</div>

<!-- Filter bar -->
<div class="filter-bar">
    <i class="fas fa-search text-muted"></i>
    <input type="text" id="searchInput" placeholder="Anket ara...">
</div>

<!-- Category pills -->
<div class="category-pills" id="categoryPills">
    <span class="cat-pill active" data-id="0">Tümü</span>
</div>

<!-- Result count -->
<div class="result-count" id="resultCount"></div>

<!-- Survey grid -->
<div class="survey-grid" id="surveyGrid">
    <div class="empty-state">
        <i class="fas fa-spinner fa-spin"></i>
        <p>Anketler yükleniyor...</p>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var api = "https://localhost:7258/api";
            var token = localStorage.getItem("token");
            var allSurveys = [];
            var activeCatId = 0;

            function titleCase(s) {
                if(!s) return "";
                return s.split(' ').map(w=>w.charAt(0).toLocaleUpperCase('tr-TR')+w.slice(1).toLocaleLowerCase('tr-TR')).join(' ');
            }

            function renderSurveys(surveys) {
                var query = $("#searchInput").val().toLowerCase();
                var filtered = surveys.filter(function(s) {
                    var title = (s.title || s.Title || "").toLowerCase();
                    var matchSearch = !query || title.includes(query);
                    var matchCat = activeCatId === 0 || (s.categoryId || s.CategoryId) == activeCatId;
                    return matchSearch && matchCat && (s.isActive || s.IsActive);
                });

                $("#resultCount").text(filtered.length + " anket bulundu");

                if (filtered.length === 0) {
                    $("#surveyGrid").html('<div class="empty-state"><i class="fas fa-clipboard"></i><p>Bu kriterlere uygun anket bulunamadı.</p></div>');
                    return;
                }

                var html = "";
                $.each(filtered, function(i, s) {
                    var title = titleCase(s.title || s.Title || "—");
                    var cat = s.categoryName || s.CategoryName || "—";
                    var id = s.id || s.Id;
                    var photo = s.photoUrl || s.PhotoUrl;

                    var imgHtml = (photo && photo !== "")
                        ? '<img class="survey-card-img" src="' + api.replace("/api","") + '/Files/Surveys/' + photo + '" onerror="this.style.display=\'none\';this.nextSibling.style.display=\'flex\';">' +
                          '<div class="survey-card-img-placeholder" style="display:none;"><i class="fas fa-clipboard-list" style="font-size:2rem;color:#6c63ff;opacity:0.3;"></i></div>'
                        : '<div class="survey-card-img-placeholder"><i class="fas fa-clipboard-list" style="font-size:2rem;color:#6c63ff;opacity:0.3;"></i></div>';

                    html += '<a class="survey-card" href="/user/survey/' + id + '">' +
                        imgHtml +
                        '<div class="survey-card-body">' +
                            '<div class="survey-card-title">' + title + '</div>' +
                            '<div class="survey-card-cat"><i class="fas fa-folder mr-1"></i>' + cat + '</div>' +
                        '</div>' +
                        '<div class="survey-card-footer">' +
                            '<span class="badge-user badge-active"><i class="fas fa-circle" style="font-size:6px;"></i> Yayında</span>' +
                            '<span class="take-btn">Katıl <i class="fas fa-arrow-right ml-1"></i></span>' +
                        '</div>' +
                        '</a>';
                });
                $("#surveyGrid").html(html);
            }

            // Load categories
            $.ajax({
                url: api + "/Category/List", type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function(cats) {
                    $.each(cats, function(i, c) {
                        if (c.isActive || c.IsActive) {
                            var name = titleCase(c.name || c.Name);
                            $("#categoryPills").append('<span class="cat-pill" data-id="' + (c.id || c.Id) + '">' + name + '</span>');
                        }
                    });
                }
            });

            // Load surveys
            $.ajax({
                url: api + "/Survey/List", type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function(surveys) {
                    allSurveys = surveys;
                    renderSurveys(allSurveys);
                },
                error: function() {
                    $("#surveyGrid").html('<div class="empty-state"><i class="fas fa-exclamation-circle text-danger"></i><p>Anketler yüklenemedi.</p></div>');
                }
            });

            // Category filter
            $(document).on("click", ".cat-pill", function() {
                $(".cat-pill").removeClass("active");
                $(this).addClass("active");
                activeCatId = parseInt($(this).data("id")) || 0;
                renderSurveys(allSurveys);
            });

            // Search
            $("#searchInput").on("input", function() {
                renderSurveys(allSurveys);
            });
        });
    </script>
}
