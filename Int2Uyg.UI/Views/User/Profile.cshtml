@{
    ViewData["Title"] = "Profilim";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .profile-card {
        background: white;
        border-radius: 24px;
        padding: 2.5rem;
        box-shadow: 0 12px 48px rgba(108, 99, 255, 0.08);
        border: 1px solid rgba(108, 99, 255, 0.06);
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2.5rem;
    }

    .profile-avatar-wrapper {
        position: relative;
    }

    .profile-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #ddd8ff;
        box-shadow: 0 8px 24px rgba(108,99,255,0.15);
    }

    .avatar-upload-btn {
        position: absolute;
        bottom: 0;
        right: 0;
        background: #6c63ff;
        color: white;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid white;
    }

    .profile-info {
        flex: 1;
    }

        .profile-info h2 {
            font-family: 'Sora', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 0.5rem;
        }

        .profile-info .role-badge {
            display: inline-block;
            background: #ede9ff;
            color: #6c63ff;
            padding: 0.3rem 1rem;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            font-family: 'Sora', sans-serif;
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .form-group-user {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

        .form-group-user label {
            font-weight: 600;
            color: #1a1a2e;
            font-size: 0.85rem;
            font-family: 'Sora', sans-serif;
        }

        .form-group-user input {
            padding: 12px 16px;
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
            font-family: 'DM Sans', sans-serif;
        }

            .form-group-user input:focus {
                outline: none;
                border-color: #6c63ff;
                box-shadow: 0 0 0 3px rgba(108,99,255,0.1);
            }

    .btn-save-user {
        background: #6c63ff;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 32px;
        font-family: 'Sora', sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 1.5rem;
    }

        .btn-save-user:hover {
            background: #5a52d5;
            transform: translateY(-1px);
        }

    .alert-floating {
        margin-top: 1rem;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        font-size: 0.9rem;
    }

    @@media (max-width: 600px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="profile-container">
    <div class="profile-card">
        <!-- Profil başlığı (fotoğraf + isim) -->
        <div class="profile-header">
            <div class="profile-avatar-wrapper">
                <img src="/sbadmin/img/undraw_profile.svg" id="userPicture" class="profile-avatar"
                     onerror="this.src='/sbadmin/img/undraw_profile.svg'">
                <label for="fileInput" class="avatar-upload-btn">
                    <i class="fas fa-camera"></i>
                </label>
                <input id="fileInput" type="file" accept="image/*" style="display: none;">
            </div>
            <div class="profile-info">
                <h2 id="displayFullName">...</h2>
                <span class="role-badge" id="roleBadge">Üye</span>
            </div>
        </div>

        <!-- Düzenleme formu -->
        <form id="frmProfile">
            <div class="form-grid">
                <div class="form-group-user">
                    <label>Ad Soyad</label>
                    <input type="text" id="txtFullName" placeholder="Adınız ve soyadınız">
                </div>
                <div class="form-group-user">
                    <label>Kullanıcı Adı</label>
                    <input type="text" id="txtUserName" readonly placeholder="Kullanıcı adı">
                </div>
                <div class="form-group-user">
                    <label>E-Posta</label>
                    <input type="email" id="txtEmail" placeholder="E-posta adresiniz">
                </div>
                <div class="form-group-user">
                    <label>Telefon</label>
                    <input type="tel" id="txtPhone" placeholder="05XXXXXXXXX">
                </div>
            </div>
            <button type="button" class="btn-save-user" id="btnSave">
                <i class="fas fa-save mr-2"></i>Değişiklikleri Kaydet
            </button>
        </form>
        <div id="divResult"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var apiBaseUrl = "https://localhost:7258/api";
            var token = localStorage.getItem("token");

            if (!token) { window.location.href = "/Login"; return; }

            function parseJwt(token) {
                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    return JSON.parse(decodeURIComponent(window.atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join('')));
                } catch (e) { return null; }
            }

            var payload = parseJwt(token);
            var userId = payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"] || payload["nameid"] || payload["sub"] || payload["Id"];
            var roles = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
            var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));

            // Rol rozetini güncelle
            if (isAdmin) {
                $("#roleBadge").text("Admin").css("background","#d1fae5").css("color","#065f46");
            } else {
                $("#roleBadge").text("Üye").css("background","#ede9ff").css("color","#6c63ff");
            }

            LoadProfile();

            function LoadProfile() {
                $.ajax({
                    url: apiBaseUrl + "/User/GetById/" + userId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        $("#txtFullName").val(data.fullName || data.FullName);
                        $("#txtUserName").val(data.userName || data.UserName);
                        $("#txtEmail").val(data.email || data.Email);
                        $("#txtPhone").val(data.phoneNumber || data.PhoneNumber);
                        $("#displayFullName").text((data.fullName || data.FullName || "Kullanıcı"));

                        var photo = data.photoUrl || data.PhotoUrl;
                        if (photo) {
                            var src = photo.startsWith("undraw")
                                ? "/sbadmin/img/" + photo
                                : apiBaseUrl.replace("/api","") + "/Files/UserPhotos/" + photo;
                            $("#userPicture").attr("src", src);
                        }
                    }
                });
            }

            // Profil fotoğrafı yükleme
            $("#fileInput").change(function () {
                var file = this.files[0];
                if (!file) return;
                var reader = new FileReader();
                reader.onload = function (e) {
                    var img = new Image();
                    img.onload = function () {
                        var canvas = document.createElement('canvas');
                        var ctx = canvas.getContext('2d');
                        var MAX = 500;
                        var w = img.width, h = img.height;
                        if (w > h) { if (w > MAX) { h *= MAX / w; w = MAX; } } else { if (h > MAX) { w *= MAX / h; h = MAX; } }
                        canvas.width = w; canvas.height = h;
                        ctx.drawImage(img, 0, 0, w, h);
                        var base64 = canvas.toDataURL('image/jpeg', 0.8);
                        UploadPhoto(base64);
                        $("#userPicture").attr("src", base64);
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });

            function UploadPhoto(base64) {
                $.ajax({
                    url: apiBaseUrl + "/User/Upload",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ userId: userId, picData: base64, picExt: ".jpg" }),
                    success: function (d) {
                        if (d.status || d.Status) showAlert(d.message || d.Message || "Fotoğraf güncellendi", "success");
                        else showAlert(d.message || d.Message, "danger");
                    },
                    error: function () { showAlert("Yükleme başarısız.", "danger"); }
                });
            }

            // Bilgileri güncelle
            $("#btnSave").click(function () {
                var userData = {
                    FullName: $("#txtFullName").val(),
                    UserName: $("#txtUserName").val(),
                    Email: $("#txtEmail").val(),
                    PhoneNumber: $("#txtPhone").val()
                };
                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-2"></i>Kaydediliyor...');
                $.ajax({
                    url: apiBaseUrl + "/User/Update",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(userData),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fas fa-save mr-2"></i>Değişiklikleri Kaydet');
                        if (d.status || d.Status) {
                            showAlert("Profil başarıyla güncellendi.", "success");
                            $("#displayFullName").text(userData.FullName);
                        } else {
                            showAlert(d.message || d.Message, "danger");
                        }
                    },
                    error: function () {
                        btn.prop("disabled", false).html('<i class="fas fa-save mr-2"></i>Değişiklikleri Kaydet');
                        showAlert("Sunucu hatası.", "danger");
                    }
                });
            });

            function showAlert(message, type) {
                $("#divResult")
                    .removeClass()
                    .addClass("alert alert-" + type + " alert-floating")
                    .html('<i class="fas fa-info-circle mr-2"></i>' + message)
                    .fadeIn(300);
                setTimeout(function () { $("#divResult").fadeOut(500); }, 4000);
            }
        });
    </script>
}