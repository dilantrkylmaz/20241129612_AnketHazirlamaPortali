<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Anket Hazırlama Portalı">
    <meta name="author" content="Dilan">

    <title>@ViewData["Title"] - Anket Portalı</title>

    <link href="~/sbadmin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #6c63ff;
            --primary-dark: #5a52d5;
            --primary-light: #ede9ff;
            --accent: #ff6584;
            --dark: #1a1a2e;
            --text: #2d2d3a;
            --muted: #6b7280;
            --bg: #f8f7ff;
            --white: #ffffff;
            --radius: 16px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Sora', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .public-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(108, 99, 255, 0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
            padding: 1rem 2rem;
            box-shadow: 0 2px 16px rgba(108, 99, 255, 0.06);
        }

        .navbar-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.25rem;
            color: var(--primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .navbar-brand i {
                font-size: 1.5rem;
            }

        .navbar-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .btn-login, .btn-register {
            background: transparent;
            color: var(--primary);
            border: 1.5px solid var(--primary);
            border-radius: 10px;
            padding: 8px 18px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 140px; 
        }

            .btn-login:hover, .btn-register:hover {
                background: var(--primary-light);
                color: var(--primary);
            }

        .public-main {
            flex: 1;
            padding: 2rem;
        }

        .public-footer {
            background: var(--white);
            border-top: 1px solid rgba(108, 99, 255, 0.08);
            padding: 1.5rem 2rem;
            text-align: center;
            font-size: 0.85rem;
            color: var(--muted);
        }

        .bg-blob {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.06;
            pointer-events: none;
            z-index: 0;
        }

        .bg-blob-1 {
            width: 400px;
            height: 400px;
            background: var(--primary);
            top: -100px;
            right: -100px;
        }

        .bg-blob-2 {
            width: 300px;
            height: 300px;
            background: var(--accent);
            bottom: 100px;
            left: -80px;
        }

        .content-wrapper {
            position: relative;
            z-index: 1;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="bg-blob bg-blob-1"></div>
    <div class="bg-blob bg-blob-2"></div>

    <nav class="public-navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-clipboard-list"></i>
                Anket Portalı
            </a>
            <div class="navbar-actions">
                <a href="/login" class="btn-login">
                    <i class="fas fa-sign-in-alt mr-1"></i> Giriş Yap
                </a>
                <a href="/register" class="btn-register">
                    <i class="fas fa-user-plus mr-1"></i> Kaydol
                </a>
            </div>
        </div>
    </nav>

    <main class="public-main content-wrapper">
        @RenderBody()
    </main>

    <footer class="public-footer">
        Anket Portalı &copy; @DateTime.Now.Year — Tüm hakları saklıdır.
    </footer>

    <script src="~/sbadmin/vendor/jquery/jquery.min.js"></script>
    <script src="~/sbadmin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            var token = localStorage.getItem("token");

            if (token) {
                var currentPath = window.location.pathname.toLowerCase();
                if (currentPath === "/" || currentPath === "/login" || currentPath === "/register" || currentPath === "/forgot-password") {
                    try {
                        function parseJwt(t) {
                            var b = t.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
                            return JSON.parse(decodeURIComponent(atob(b).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('')));
                        }
                        var payload = parseJwt(token);
                        var roles = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                        var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));

                        if (isAdmin) {
                            window.location.href = "/admin";
                        } else {
                            window.location.href = "/user";
                        }
                    } catch (e) {
                        localStorage.removeItem("token");
                    }
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>