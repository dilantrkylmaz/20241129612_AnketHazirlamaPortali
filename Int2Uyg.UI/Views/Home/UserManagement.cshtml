@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="row">
    <!-- Kullanıcı Listesi -->
    <div class="col-md-8" id="listArea">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-primary text-white">
                <h6 class="m-0 font-weight-bold"><i class="fas fa-users mr-2"></i>Sistemdeki Kullanıcılar</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="tbUserList" width="100%" cellspacing="0">
                        <thead>
                            <tr class="bg-light text-dark">
                                <th style="width:55px;">Foto</th>
                                <th>Ad Soyad</th>
                                <th>Kullanıcı Adı</th>
                                <th>E-Posta</th>
                                <th>Telefon</th>
                                <th style="width:110px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Kullanıcı Düzenleme Paneli -->
    <div class="col-md-4" id="formArea" style="display:none;">
        <div class="card shadow mb-4 border-left-warning position-sticky" style="top: 1.5rem;">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-warning" id="formTitle">
                    <i class="fas fa-user-cog mr-1"></i> Kullanıcı Düzenle
                </h6>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <img id="editUserPhoto" src="/sbadmin/img/undraw_profile.svg"
                         class="img-profile rounded-circle shadow"
                         style="width:90px;height:90px;object-fit:cover;border:3px solid #f6c23e;"
                         onerror="this.src='/sbadmin/img/undraw_profile.svg'">
                </div>

                <table class="table table-sm table-borderless small mb-3">
                    <tr>
                        <td class="font-weight-bold text-muted">Ad Soyad:</td>
                        <td id="editFullName">—</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Kullanıcı Adı:</td>
                        <td id="editUserName">—</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">E-Posta:</td>
                        <td id="editEmail">—</td>
                    </tr>
                </table>

                <hr>

                <div class="form-group">
                    <label class="font-weight-bold text-dark small">Rol Değiştir</label>
                    <select class="form-control" id="cbRole">
                        <option value="Uye">Üye</option>
                        <option value="Admin">Admin</option>
                    </select>
                    <small class="text-muted">Mevcut rol tabloda <span class="badge badge-info" id="currentRoleBadge">—</span> olarak görünmektedir.</small>
                </div>

                <button type="button" class="btn btn-warning btn-block font-weight-bold shadow-sm" id="btnChangeRole">
                    <i class="fas fa-exchange-alt mr-1"></i> Rolü Güncelle
                </button>
                <button type="button" class="btn btn-secondary btn-block shadow-sm" id="btnCancel">
                    <i class="fas fa-times mr-1"></i> Vazgeç
                </button>

                <div id="divResult" class="mt-3" style="display:none;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var apiBaseUrl = "https://localhost:7258/api";
            var token = localStorage.getItem("token");

            if (!token) { window.location.href = "/Login"; return; }

            function parseJwt(token) {
                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    return JSON.parse(decodeURIComponent(window.atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join('')));
                } catch (e) { return null; }
            }

            var payload = parseJwt(token);
            var roles = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
            var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));

            if (!isAdmin) {
                window.location.href = "/Home/Index";
                return;
            }

            var selectedUserId = null;

            GetUserList();

            function GetUserList() {
                $.ajax({
                    url: apiBaseUrl + "/User/List",
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        var rows = "";
                        $("#tbUserList tbody").empty();

                        $.each(data, function (i, user) {
                            var photo = user.photoUrl || user.PhotoUrl || "undraw_profile.svg";
                            var imgPath = photo.startsWith("undraw")
                                ? "/sbadmin/img/" + photo
                                : apiBaseUrl.replace("/api", "") + "/Files/UserPhotos/" + photo;

                            rows += "<tr>";
                            rows += '<td><img src="' + imgPath + '" onerror="this.src=\'/sbadmin/img/undraw_profile.svg\'" class="rounded-circle" style="width:38px;height:38px;object-fit:cover;"></td>';
                            rows += "<td class='font-weight-bold'>" + toTitleCase(user.fullName || user.FullName || "—") + "</td>";
                            rows += "<td>" + (user.userName || user.UserName || "—") + "</td>";
                            rows += "<td>" + (user.email || user.Email || "—") + "</td>";
                            rows += "<td>" + (user.phoneNumber || user.PhoneNumber || "—") + "</td>";
                            rows += '<td><button class="btn btn-warning btn-sm btnEdit" data-id="' + (user.id || user.Id) + '"><i class="fa fa-user-cog"></i> Düzenle</button></td>';
                            rows += "</tr>";
                        });

                        $("#tbUserList tbody").append(rows);
                    },
                    error: function () {
                        showResult("Kullanıcı listesi yüklenemedi!", "danger");
                    }
                });
            }

            // Düzenle butonuna tıklayınca
            $(document).on("click", ".btnEdit", function () {
                var userId = $(this).data("id");
                selectedUserId = userId;

                $.ajax({
                    url: apiBaseUrl + "/User/GetById/" + userId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (user) {
                        var photo = user.photoUrl || user.PhotoUrl || "undraw_profile.svg";
                        var imgPath = photo.startsWith("undraw")
                            ? "/sbadmin/img/" + photo
                            : apiBaseUrl.replace("/api", "") + "/Files/UserPhotos/" + photo;

                        $("#editUserPhoto").attr("src", imgPath);
                        $("#editFullName").text(toTitleCase(user.fullName || user.FullName || "—"));
                        $("#editUserName").text(user.userName || user.UserName || "—");
                        $("#editEmail").text(user.email || user.Email || "—");

                        // Mevcut rolü bulmak için JWT'deki kullanıcının rolünü kullanamazız,
                        // listeden gelmiyor; varsayılan "Uye" seç
                        $("#cbRole").val("Uye");
                        $("#currentRoleBadge").text("Bilinmiyor");

                        $("#listArea").removeClass("col-md-12").addClass("col-md-8");
                        $("#formArea").fadeIn();

                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                });
            });

            // Rol Değiştir
            $("#btnChangeRole").click(function () {
                if (!selectedUserId) return;

                var newRole = $("#cbRole").val();
                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Güncelleniyor...');

                $.ajax({
                    url: apiBaseUrl + "/User/ChangeRole",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ UserId: selectedUserId, RoleName: newRole }),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fas fa-exchange-alt mr-1"></i> Rolü Güncelle');
                        if (d.status || d.Status) {
                            showResult("Rol başarıyla <strong>" + newRole + "</strong> olarak değiştirildi!", "success");
                            $("#currentRoleBadge").text(newRole);
                        } else {
                            showResult(d.message || "Güncellenemedi.", "danger");
                        }
                    },
                    error: function () {
                        btn.prop("disabled", false).html('<i class="fas fa-exchange-alt mr-1"></i> Rolü Güncelle');
                        showResult("Sunucu hatası!", "danger");
                    }
                });
            });

            $("#btnCancel").click(function () {
                $("#formArea").fadeOut();
                $("#listArea").removeClass("col-md-8").addClass("col-md-12");
                selectedUserId = null;
            });

            function showResult(message, type) {
                $("#divResult").stop(true, true).hide()
                    .removeClass().addClass("alert alert-" + type + " shadow-sm")
                    .html('<i class="fas fa-info-circle mr-2"></i>' + message).fadeIn(400);
                setTimeout(function () { $("#divResult").fadeOut(800); }, 4000);
            }

            function toTitleCase(str) {
                if (!str) return "";
                return str.split(' ').map(function (word) {
                    return word.charAt(0).toLocaleUpperCase('tr-TR') + word.slice(1).toLocaleLowerCase('tr-TR');
                }).join(' ');
            }
        });
    </script>
}
