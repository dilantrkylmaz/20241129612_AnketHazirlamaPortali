@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<style>
    .login-container {
        max-width: 450px;
        margin: 2rem auto;
        background: white;
        border-radius: 20px;
        padding: 3rem 2rem;
        box-shadow: 0 12px 48px rgba(108, 99, 255, 0.12);
        border: 1px solid rgba(108, 99, 255, 0.08);
    }

    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .login-header p {
        color: #6b7280;
        font-size: 0.95rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-group input {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 0.95rem;
        transition: all 0.2s;
        font-family: 'Sora', sans-serif;
    }

    .form-group input:focus {
        outline: none;
        border-color: #6c63ff;
        box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.08);
    }

    .form-group.password-group {
        position: relative;
    }

    .toggle-password {
        position: absolute;
        right: 14px;
        top: 43px;
        cursor: pointer;
        color: #6b7280;
        transition: color 0.2s;
    }

    .toggle-password:hover {
        color: #6c63ff;
    }

    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, #6c63ff 0%, #5a52d5 100%);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 1rem;
        font-family: 'Sora', sans-serif;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(108, 99, 255, 0.4);
        color: white;
        text-decoration: none;
    }

    .login-footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }

    .login-footer a {
        color: #6c63ff;
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s;
        font-size: 0.9rem;
    }

    .login-footer a:hover {
        color: #5a52d5;
    }

    .login-footer p {
        color: #6b7280;
        margin: 0.5rem 0;
        font-size: 0.9rem;
    }

    .alert {
        border-radius: 10px;
        border: none;
        padding: 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }
</style>

<div class="login-container">
    <div class="login-header">
        <h1>Giriş Yap</h1>
        <p>Anket portalına erişmek için oturum açın</p>
    </div>

    <form id="loginForm">
        <div class="form-group">
            <label for="txtUserName">Kullanıcı Adı</label>
            <input type="text" class="form-control" id="txtUserName" placeholder="Kullanıcı adınızı girin" required>
        </div>

        <div class="form-group password-group">
            <label for="txtPassword">Parola</label>
            <input type="password" class="form-control" id="txtPassword" placeholder="Parolanızı girin" required>
            <i class="fas fa-eye toggle-password" id="togglePassword"></i>
        </div>

        <button type="button" id="btnLogin" class="btn-login">
            <i class="fas fa-sign-in-alt mr-2"></i> Giriş Yap
        </button>
    </form>

    <div id="divResult"></div>

    <div class="login-footer">
        <p>Henüz hesabınız yok mu?</p>
        <a href="/register">
            <i class="fas fa-user-plus mr-1"></i> Yeni Üye Kaydı Oluştur
        </a>
        <p style="margin-top: 1rem;">
            <a href="ForgotPassword">Şifremi Unuttum?</a>
        </p>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var apiBaseUrl = "https://localhost:7258/api";

            // Göz İkonu (Şifre Göster/Gizle)
            $("#togglePassword").click(function () {
                var passwordInput = $("#txtPassword");
                var icon = $(this);

                if (passwordInput.attr("type") === "password") {
                    passwordInput.attr("type", "text");
                    icon.removeClass("fa-eye").addClass("fa-eye-slash");
                } else {
                    passwordInput.attr("type", "password");
                    icon.removeClass("fa-eye-slash").addClass("fa-eye");
                }
            });

            // Giriş İşlemi
            $("#btnLogin").click(function () {
                var userName = $("#txtUserName").val().trim();
                var password = $("#txtPassword").val();

                if (!userName || !password) {
                    showResult("Kullanıcı adı ve şifre gereklidir!", "danger");
                    return;
                }

                $(this).prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Yükleniyor...');

                var loginData = {
                    UserName: userName,
                    Password: password
                };

                $.ajax({
                    url: apiBaseUrl + "/User/SignIn",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(loginData),
                    success: function (response) {
                        if (response.status) {
                            localStorage.setItem("token", response.message);
                            showResult("Giriş Başarılı! Yönlendiriliyorsunuz...", "success");
                            setTimeout(function () {
                                // Redirect based on role
                                try {
                                    function parseJwt(t) {
                                        var b = t.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
                                        return JSON.parse(decodeURIComponent(atob(b).split('').map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)).join('')));
                                    }
                                    var payload = parseJwt(response.message);
                                    var roles = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                                    var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));
                                    window.location.href = isAdmin ? "/admin" : "/user";
                                } catch (e) {
                                    window.location.href = "/user";
                                }
                            }, 1000);
                        } else {
                            showResult(response.message, "danger");
                            $("#btnLogin").prop("disabled", false).html('<i class="fas fa-sign-in-alt mr-2"></i> Giriş Yap');
                        }
                    },
                    error: function () {
                        showResult("Sunucu bağlantı hatası!", "danger");
                        $("#btnLogin").prop("disabled", false).html('<i class="fas fa-sign-in-alt mr-2"></i> Giriş Yap');
                    }
                });
            });

            function showResult(message, type) {
                $("#divResult")
                    .removeClass()
                    .addClass("alert alert-" + type)
                    .html(message)
                    .fadeIn();
            }
        });
    </script>
}