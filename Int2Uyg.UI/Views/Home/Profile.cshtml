@{
    ViewData["Title"] = "Profilim";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-primary">
                    <h6 class="m-0 font-weight-bold text-white"><i class="fas fa-user-edit mr-2"></i>Kullanıcı Bilgileri</h6>
                </div>
                <div class="card-body">
                    <form id="frmProfile">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="font-weight-bold text-dark">Adınız Soyadınız</label>
                                <input type="text" id="txtFullName" class="form-control" placeholder="Ad Soyad giriniz">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="font-weight-bold text-dark">Kullanıcı Adı</label>
                                <input type="text" id="txtUserName" class="form-control" placeholder="Kullanıcı adını değiştirin" readonly>
                                <small class="text-muted">Kullanıcı adı değiştirilemez.</small>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="font-weight-bold text-dark">E-Posta</label>
                                <input type="email" id="txtEmail" class="form-control" placeholder="E-posta adresi">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="font-weight-bold text-dark">Telefon</label>
                                <input type="text" id="txtPhone" class="form-control" placeholder="Telefon numarası">
                            </div>
                        </div>
                        <hr>
                        <button type="button" class="btn btn-primary shadow-sm font-weight-bold" id="btnSave">
                            <i class="fas fa-save mr-1"></i> Değişiklikleri Kaydet
                        </button>
                    </form>
                    <div id="divResult" class="mt-3" style="display:none;"></div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-success text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-camera mr-2"></i>Profil Fotoğrafı</h6>
                </div>
                <div class="card-body text-center">
                    <img src="/sbadmin/img/undraw_profile.svg" id="userPicture" class="img-profile rounded-circle mb-3 shadow" style="width:180px; height:180px; object-fit: cover; border: 4px solid #f8f9fc;" onerror="this.src='/sbadmin/img/undraw_profile.svg'">
                    <div class="mt-2">
                        <input id="fileInput" type="file" accept="image/*" style="display: none;">
                        <button class="btn btn-outline-success btn-sm btn-block" onclick="$('#fileInput').click();">
                            <i class="fas fa-upload mr-1"></i> Yeni Fotoğraf Seç
                        </button>
                    </div>
                    <small class="text-muted mt-2 d-block">Her boyuttaki resim otomatik uyarlanır.</small>
                    <div id="divUploadResult" class="mt-2"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // 🛡️ API Adresini sabitledik
            var apiBaseUrl = "https://localhost:7258/api";
            var token = localStorage.getItem("token");

            if (!token) { window.location.href = "/Login"; return; }

            // Güvenli Token Çözücü
            function parseJwt(token) {
                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join(''));
                    return JSON.parse(jsonPayload);
                } catch (e) { return null; }
            }

            var payload = parseJwt(token);
            var userId = payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"] || payload["nameid"] || payload["sub"] || payload["Id"];

            GetUserInfo();

            // 🟢 BİLGİLERİ VE RESMİ GETİRME
            function GetUserInfo() {
                $.ajax({
                    url: apiBaseUrl + "/User/GetById/" + userId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        $("#txtFullName").val(data.fullName || data.FullName);
                        $("#txtUserName").val(data.userName || data.UserName);
                        $("#txtEmail").val(data.email || data.Email);
                        $("#txtPhone").val(data.phoneNumber || data.PhoneNumber);

                        var photo = data.photoUrl || data.PhotoUrl;
                        if (photo) {
                            var imgPath = "";
                            // 💡 KRİTİK DÜZELTME: Otomatik ikon ise sbadmin klasöründen al, özel resimse Files'tan al!
                            if (photo.startsWith("undraw")) {
                                imgPath = "/sbadmin/img/" + photo;
                            } else {
                                imgPath = apiBaseUrl.replace("/api", "") + "/Files/UserPhotos/" + photo;
                            }
                            $("#userPicture").attr("src", imgPath);
                            $("#topProfileImage").attr("src", imgPath); // Sağ üstü de senkronize et
                        }
                    }
                });
            }

            // 🟢 BİLGİLERİ GÜNCELLEME
            $("#btnSave").click(function () {
                var userData = {
                    FullName: $("#txtFullName").val(),
                    UserName: $("#txtUserName").val(),
                    Email: $("#txtEmail").val(),
                    PhoneNumber: $("#txtPhone").val()
                };

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Kaydediliyor...');

                $.ajax({
                    url: apiBaseUrl + "/User/Update",
                    type: "PUT",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(userData),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fas fa-save mr-1"></i> Değişiklikleri Kaydet');
                        if (d.status || d.Status) {
                            showResult("Profiliniz başarıyla güncellendi!", "success");
                            $("#userNameSpan").text(toTitleCase(userData.FullName)); // Sağ üstteki ismi anında değiştir
                        } else {
                            showResult(d.message || d.Message, "danger");
                        }
                    },
                    error: function() {
                        btn.prop("disabled", false).html('<i class="fas fa-save mr-1"></i> Değişiklikleri Kaydet');
                        showResult("Hata oluştu. Lütfen tekrar deneyin.", "danger");
                    }
                });
            });

            // 📸 RESİM SEÇME, SIKIŞTIRMA VE SAĞ ÜSTÜ ANINDA GÜNCELLEME (400 Hatasını Önler)
            $("#fileInput").change(function () {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        var img = new Image();
                        img.onload = function () {
                            var canvas = document.createElement('canvas');
                            var ctx = canvas.getContext('2d');
                            var MAX = 600; // Profil resmi için 600px yeterli
                            var w = img.width, h = img.height;
                            if (w > h) { if (w > MAX) { h *= MAX / w; w = MAX; } } else { if (h > MAX) { w *= MAX / h; h = MAX; } }
                            canvas.width = w; canvas.height = h;
                            ctx.drawImage(img, 0, 0, w, h);
                            var compressedBase64 = canvas.toDataURL('image/jpeg', 0.8);

                            // 🚀 EKRANDAKİ RESİMLERİ ANINDA DEĞİŞTİR
                            $('#userPicture').attr('src', compressedBase64);
                            $('#topProfileImage').attr('src', compressedBase64);

                            // API'YE GÖNDER
                            UploadPhoto(compressedBase64);
                        };
                        img.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });

            function UploadPhoto(base64Data) {
                var uploadData = {
                    userId: userId,
                    picData: base64Data,
                    picExt: ".jpg"
                };

                $.ajax({
                    url: apiBaseUrl + "/User/Upload",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(uploadData),
                    success: function (d) {
                        if(d.status || d.Status) {
                            showResult("Fotoğraf başarıyla yüklendi ve güncellendi!", "success");
                        } else {
                            showResult(d.message || "Yükleme başarısız.", "danger");
                        }
                    },
                    error: function() {
                        showResult("Resim çok büyük veya bağlantı hatası!", "danger");
                    }
                });
            }

            function showResult(message, type) {
                $("#divResult").stop(true,true).hide().removeClass().addClass("alert alert-" + type).html('<i class="fas fa-info-circle mr-2"></i>' + message).fadeIn(500);
                setTimeout(function() { $("#divResult").fadeOut(1000); }, 4000);
            }

            function toTitleCase(str) {
                if(!str) return "";
                return str.split(' ').map(function(word) { return word.charAt(0).toLocaleUpperCase('tr-TR') + word.slice(1).toLocaleLowerCase('tr-TR'); }).join(' ');
            }
        });
    </script>
}