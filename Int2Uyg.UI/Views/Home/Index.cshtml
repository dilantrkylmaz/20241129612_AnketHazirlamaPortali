@{
    ViewData["Title"] = "Anket Portalı";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #6c63ff 0%, #ff6584 100%);
        border-radius: 24px;
        padding: 4rem 3rem;
        color: white;
        margin: 3rem auto;
        position: relative;
        overflow: hidden;
        max-width: 900px;
        text-align: center;
        box-shadow: 0 16px 48px rgba(108, 99, 255, 0.2);
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 50%;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .hero-section p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-btn {
        background: white;
        color: #6c63ff;
        border: none;
        border-radius: 12px;
        padding: 14px 32px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    }

    .hero-btn:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        color: #5a52d5;
        text-decoration: none;
    }

    .hero-btn-secondary {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 2px solid white;
    }

    .hero-btn-secondary:hover {
        background: rgba(255, 255, 255, 0.3);
        color: white;
        text-decoration: none;
    }

    .features {
        max-width: 1000px;
        margin: 4rem auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        padding: 0 1rem;
    }

    .feature-card {
        background: white;
        border-radius: 16px;
        padding: 2rem;
        text-align: center;
        box-shadow: 0 4px 24px rgba(108, 99, 255, 0.08);
        border: 1px solid rgba(108, 99, 255, 0.06);
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(108, 99, 255, 0.15);
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #6c63ff, #ff6584);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.75rem;
        margin: 0 auto 1rem;
    }

    .feature-card h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0.5rem;
    }

    .feature-card p {
        color: #6b7280;
        font-size: 0.9rem;
        line-height: 1.5;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <div class="hero-content">
        <h1>Anketler ile Görüş Topla 📊</h1>
        <p>Profesyonel anketler oluşturun, yayınlayın ve sonuçları analiz edin. Karar almak için gereken verileri elde edin.</p>
        
        <div class="hero-buttons">
            <a href="/register" class="hero-btn">
                <i class="fas fa-user-plus"></i> Ücretsiz Kaydol
            </a>
            <a href="/login" class="hero-btn hero-btn-secondary">
                <i class="fas fa-sign-in-alt"></i> Giriş Yap
            </a>
        </div>
    </div>
</div>

<!-- Features Section -->
<section class="features">
    <div class="feature-card">
        <div class="feature-icon">
            <i class="fas fa-pencil-alt"></i>
        </div>
        <h3>Kolay Anket Oluştur</h3>
        <p>Sürükle-bırak arayüzü ile saniyeler içinde profesyonel anketler tasarla.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon">
            <i class="fas fa-share-alt"></i>
        </div>
        <h3>Hızlı Paylaş</h3>
        <p>Anketini sosyal medya, e-posta veya doğrudan bağlantı ile paylaş.</p>
    </div>

    <div class="feature-card">
        <div class="feature-icon">
            <i class="fas fa-chart-bar"></i>
        </div>
        <h3>Sonuçları Analiz Et</h3>
        <p>Gerçek zamanlı grafikler ve detaylı raporlarla sonuçları görüntüle.</p>
    </div>
</section>
