@{
    ViewData["Title"] = "Anket Soruları ve Şıklar";
}

<style>
    li.option-item {
        cursor: pointer;
        transition: 0.2s ease-in-out;
        border-left: 5px solid transparent !important;
    }

        li.option-item:hover {
            background-color: #f8f9fc !important;
            border-left: 5px solid #4e73df !important;
        }

    li.option-selected {
        background-color: #d1ecf1 !important;
        border-left: 5px solid #0c5460 !important;
        font-weight: bold;
        color: #0c5460 !important;
    }
</style>

<div class="row">
    <div class="col-md-8" id="questionsColumn">
        <div class="d-sm-flex align-items-center justify-content-between mb-4">
            <h1 class="h4 mb-0 text-gray-800 font-weight-bold"><i class="fas fa-list-ol mr-2 text-primary"></i>Sorular ve Cevap Şıkları</h1>
            <a href="/Surveys" class="btn btn-sm btn-secondary shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Anketlere Dön
            </a>
        </div>
        <div id="questionsListArea">
            <div class="text-center text-muted my-4" id="loadingDiv">
                <i class="fas fa-spinner fa-spin fa-2x mb-2"></i><p>Sorular Yükleniyor...</p>
            </div>
        </div>
    </div>

    <div class="col-md-4" id="addQuestionColumn" style="display:none;">
        <div class="card shadow mb-4 border-bottom-success position-sticky" style="top: 1.5rem;">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 font-weight-bold text-success"><i class="fas fa-plus-circle mr-2"></i>Yeni Soru Ekle</h6>
            </div>
            <div class="card-body bg-light">
                <form id="frmQuestion">
                    <div class="form-group">
                        <textarea class="form-control shadow-sm" id="txtQuestionText" rows="4" placeholder="Ankete eklenecek soruyu buraya yazın..."></textarea>
                    </div>
                    <button type="button" class="btn btn-success btn-block shadow-sm font-weight-bold" id="btnSaveQuestion">
                        <i class="fa fa-save mr-1"></i> Soruyu Ankete Ekle
                    </button>
                </form>
                <div id="divResult" class="mt-3" style="display:none;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
               $(document).ready(function () {
            var apiBaseUrl = "https://localhost:7258/api";
            var token = localStorage.getItem("token");

            var urlParts = window.location.pathname.split('/');
            var currentSurveyId = parseInt(urlParts[urlParts.length - 1]);

            if (!token || isNaN(currentSurveyId)) { window.location.href = "/Surveys"; return; }

            function parseJwt(token) {
                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    return JSON.parse(decodeURIComponent(window.atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join('')));
                } catch (e) { return null; }
            }

            var payload = parseJwt(token);
            var currentUserId = payload["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier"] || payload["nameid"] || payload["Id"];
            var roles = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
            var isAdmin = roles && (roles === "Admin" || roles.includes("Admin"));
            var canEdit = false;

            $.ajax({
                url: apiBaseUrl + "/Survey/GetById/" + currentSurveyId,
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (survey) {
                    var ownerId = survey.userId || survey.appUserId || survey.UserId || survey.AppUserId;
                    if (isAdmin || ownerId == currentUserId) {
                        canEdit = true;
                        $("#addQuestionColumn").fadeIn();
                    } else {
                        $("#questionsColumn").removeClass("col-md-8").addClass("col-md-12");
                    }
                    GetQuestions();
                },
                error: function() { GetQuestions(); }
            });

            function GetQuestions() {
                $.ajax({
                    url: apiBaseUrl + "/Question/GetQuestionsBySurveyId/" + currentSurveyId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        $("#loadingDiv").hide();
                        var container = $("#questionsListArea").empty();

                        if (!data || data.length === 0) {
                            container.append('<div class="alert alert-info shadow-sm"><i class="fas fa-info-circle mr-2"></i>Bu ankete henüz soru eklenmemiş.</div>');
                            return;
                        }

                        $.each(data, function (i, item) {
                            // 🛡️ DÜZELTME 1: ID Uyuşmazlığına Karşı Tam Koruma (Undefined Hatası Çözümü)
                            var qId = item.id || item.Id || item.questionId || item.QuestionId;
                            var text = item.text || item.Text || item.title || item.Title || "Soru metni bulunamadı";

                            var deleteBtn = canEdit ? '<button class="btn btn-danger btn-sm btnDeleteQuestion shadow-sm" data-id="' + qId + '" title="Soruyu Sil"><i class="fas fa-trash-alt"></i></button>' : '';

                            var addOptHtml = canEdit ?
                                '<div class="input-group mt-3 w-75">' +
                                    '<input type="text" class="form-control bg-light" id="txtOption_' + qId + '" placeholder="Bu soruya yeni bir şık ekleyin...">' +
                                    '<div class="input-group-append">' +
                                        '<button class="btn btn-success btnAddOption" data-questionid="' + qId + '"><i class="fas fa-plus mr-1"></i> Ekle</button>' +
                                    '</div>' +
                                '</div>' : '';

                            var submitAnswerBtn = !canEdit ?
                                '<button class="btn btn-primary btn-sm mt-3 btnSubmitAnswer font-weight-bold" data-questionid="' + qId + '"><i class="fas fa-paper-plane mr-1"></i> Seçtiğim Cevabı Kaydet</button>' : '';

                            var qCard = '<div class="card shadow-sm mb-4 border-0">' +
                                '<div class="card-header py-3 bg-primary d-flex flex-row align-items-center justify-content-between">' +
                                    '<h6 class="m-0 font-weight-bold text-white" style="font-size:1.1rem;">Soru ' + (i + 1) + ': ' + text + '</h6>' +
                                    deleteBtn +
                                '</div>' +
                                '<div class="card-body border-bottom-primary border-right-primary border-left-primary">' +
                                    '<h6 class="font-weight-bold text-success mb-3"><i class="fas fa-check-square mr-2"></i>Cevap Şıkları:</h6>' +
                                    '<ul class="list-group mb-3 option-list" id="optionList_' + qId + '"></ul>' +
                                    addOptHtml +
                                    submitAnswerBtn +
                                '</div>' +
                            '</div>';

                            container.append(qCard);

                            if (qId) { LoadOptions(qId); } // qId varsa şıkları yükle
                        });
                    }
                });
            }

            function LoadOptions(qId) {
                $.ajax({
                    url: apiBaseUrl + "/QuestionOption/GetOptionsByQuestionId/" + qId,
                    type: "GET",
                    headers: { "Authorization": "Bearer " + token },
                    success: function (data) {
                        var ul = $("#optionList_" + qId).empty();
                        var alphabet = ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J"];

                        if(data.length === 0) {
                            ul.append('<li class="list-group-item text-muted small border-0 bg-light">Henüz şık eklenmemiş.</li>');
                        }

                        $.each(data, function (idx, opt) {
                            var optId = opt.id || opt.Id || opt.questionOptionId || opt.QuestionOptionId;
                            var optText = opt.optionText || opt.OptionText;

                            var delOptBtn = canEdit ? '<button class="btn btn-sm btn-outline-danger btnDeleteOption" data-id="' + optId + '" data-q="' + qId + '" title="Şıkkı Sil"><i class="fas fa-times"></i></button>' : '';

                            // 🛡️ DÜZELTME 2: Şıkların ID'si (data-id) HTML içine gizlendi (Veritabanına kaydetmek için lazım)
                            var liHtml = '<li class="list-group-item d-flex justify-content-between align-items-center border-left-success mb-1 shadow-sm rounded option-item" data-id="' + optId + '">' +
                                '<span class="text-dark"><strong class="text-primary mr-2">' + (alphabet[idx] || "-") + ')</strong> ' + optText + '</span>' +
                                delOptBtn +
                            '</li>';
                            ul.append(liHtml);
                        });
                    }
                });
            }

            // Şıkkın seçilme mantığı
            $(document).on("click", "li.option-item", function (e) {
                if ($(e.target).closest('button').length > 0) return;
                $(this).parent().find('li.option-item').removeClass("option-selected");
                $(this).addClass("option-selected");
            });

            // 🚀 BÜYÜK YENİLİK: ANKETİ GERÇEKTEN ÇÖZME VE VERİTABANINA KAYDETME!
            $(document).on("click", ".btnSubmitAnswer", function () {
                var qId = $(this).data("questionid");
                var selectedOption = $("#optionList_" + qId + " .option-selected");

                if (selectedOption.length === 0) {
                    alert("⚠️ Lütfen anketi çözmek için önce bir şık seçiniz!");
                    return;
                }

                var optionId = selectedOption.data("id"); // Seçilen şıkkın ID'sini yakala

                var btn = $(this);
                var originalHtml = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin mr-1"></i> Kaydediliyor...').prop("disabled", true);

                // Veritabanına gidecek olan Cevap Paketi (AnswerDto)
                var answerData = {
                    QuestionId: parseInt(qId),
                    QuestionOptionId: parseInt(optionId),
                    UserId: currentUserId
                };

                $.ajax({
                    url: apiBaseUrl + "/Answer/Add",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(answerData),
                    success: function (d) {
                        // Kayıt başarılı olduğunda butonu yeşil yap
                        btn.html('<i class="fas fa-check-circle mr-1"></i> Cevabınız Kaydedildi').removeClass('btn-primary').addClass('btn-success');
                        // Şıkları kilitler, değiştirilemez yapar
                        $("#optionList_" + qId).find('li.option-item').removeClass("option-item").css("cursor", "default");
                    },
                    error: function () {
                        alert("Sistem Hatası: Cevabınız sunucuya kaydedilemedi!");
                        btn.html(originalHtml).prop("disabled", false);
                    }
                });
            });

            // Soru ve Şık Ekleme/Silme işlemleri önceki gibi kusursuz çalışmaya devam eder...
            // (Aşağıdaki metotlar eskiyle aynıdır)

            $("#btnSaveQuestion").click(function () {
                if(!canEdit) return;
                var text = $("#txtQuestionText").val();
                if (!text || text.trim() === "") { showResult("Lütfen soru metnini yazın!", "warning"); return; }
                var qData = { SurveyId: currentSurveyId, Text: text.trim(), IsActive: true, QuestionOptions: [] };
                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Kaydediliyor...');
                $.ajax({
                    url: apiBaseUrl + "/Question/Add",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify(qData),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fa fa-save mr-1"></i> Soruyu Ankete Ekle');
                        if (d.status || d.Status) { $("#txtQuestionText").val(""); GetQuestions(); showResult("Soru eklendi!", "success"); }
                    }
                });
            });

            $(document).on("click", ".btnAddOption", function () {
                if(!canEdit) return;
                var btn = $(this);
                var qId = btn.attr("data-questionid");
                var optText = $("#txtOption_" + qId).val();
                if (!optText || optText.trim() === "") return;
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i>');
                $.ajax({
                    url: apiBaseUrl + "/QuestionOption/Add",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ QuestionId: parseInt(qId), OptionText: optText.trim() }),
                    success: function (d) {
                        btn.prop("disabled", false).html('<i class="fas fa-plus mr-1"></i> Ekle');
                        if (d.status || d.Status) { $("#txtOption_" + qId).val(""); LoadOptions(qId); }
                    }
                });
            });

            $(document).on("click", ".btnDeleteOption", function (e) {
                e.stopPropagation();
                if(!canEdit) return;
                var btn = $(this);
                var optId = btn.attr("data-id");
                var qId = btn.attr("data-q");
                $.ajax({
                    url: apiBaseUrl + "/QuestionOption/Delete/" + optId,
                    type: "DELETE",
                    headers: { "Authorization": "Bearer " + token },
                    success: function () { LoadOptions(qId); }
                });
            });

            $(document).on("click", ".btnDeleteQuestion", function () {
                if(!canEdit) return;
                var qId = $(this).attr("data-id");
                if (confirm("Soruyu ve altındaki şıkları kalıcı olarak silmek istediğinize emin misiniz?")) {
                    $.ajax({
                        url: apiBaseUrl + "/Question/Delete/" + qId,
                        type: "DELETE",
                        headers: { "Authorization": "Bearer " + token },
                        success: function () { GetQuestions(); }
                    });
                }
            });

            function showResult(message, type) {
                $("#divResult").stop(true, true).hide()
                    .removeClass().addClass("alert alert-" + type + " p-2 shadow-sm rounded")
                    .html('<i class="fas fa-info-circle mr-1"></i> ' + message).fadeIn(500);
                setTimeout(function() { $("#divResult").fadeOut(1000); }, 4000);
            }
        });
    </script>
}