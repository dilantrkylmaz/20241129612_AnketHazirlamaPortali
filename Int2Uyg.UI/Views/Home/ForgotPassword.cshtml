@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "~/Views/Shared/_LayoutPublic.cshtml";
}

<style>
    .forgot-container {
        max-width: 450px;
        margin: 2rem auto;
        background: white;
        border-radius: 20px;
        padding: 3rem 2rem;
        box-shadow: 0 12px 48px rgba(108, 99, 255, 0.12);
        border: 1px solid rgba(108, 99, 255, 0.08);
    }

    .forgot-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .forgot-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 0.5rem;
        }

        .forgot-header p {
            color: #6b7280;
            font-size: 0.95rem;
            line-height: 1.5;
        }

    .form-group {
        margin-bottom: 1.5rem;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .form-group input {
            width: 100%;
            padding: 12px 14px;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            font-size: 0.95rem;
            transition: all 0.2s;
            font-family: 'Sora', sans-serif;
        }

            .form-group input:focus {
                outline: none;
                border-color: #6c63ff;
                box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.08);
            }

    .btn-reset {
        width: 100%;
        background: linear-gradient(135deg, #6c63ff 0%, #5a52d5 100%);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s;
        margin-top: 1rem;
        font-family: 'Sora', sans-serif;
    }

        .btn-reset:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(108, 99, 255, 0.4);
        }

    .forgot-footer {
        text-align: center;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }

        .forgot-footer a {
            color: #6c63ff;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
            font-size: 0.9rem;
            display: inline-block;
            margin: 0 0.75rem;
        }

            .forgot-footer a:hover {
                color: #5a52d5;
            }

    .alert {
        border-radius: 10px;
        border: none;
        padding: 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .alert-warning {
        background: #fef3c7;
        color: #92400e;
    }
</style>

<div class="forgot-container">
    <div class="forgot-header">
        <h1>Şifrenizi mi Unuttunuz?</h1>
        <p>E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
    </div>

    <form id="frmForgot">
        <div class="form-group">
            <label for="txtEmail">E-Posta Adresi</label>
            <input type="email" class="form-control" id="txtEmail"
                   placeholder="ornek@mail.com" required>
        </div>

        <button type="button" id="btnReset" class="btn-reset">
            <i class="fas fa-paper-plane mr-2"></i> Sıfırlama Bağlantısı Gönder
        </button>
    </form>

    <div id="divResult" class="mt-3" style="display:none;"></div>

    <div class="forgot-footer">
        <a href="/login"><i class="fas fa-sign-in-alt mr-1"></i> Giriş Yap</a>
        <a href="/register"><i class="fas fa-user-plus mr-1"></i> Kayıt Ol</a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#btnReset").click(function () {
                var email = $("#txtEmail").val().trim();
                var btn = $(this);

                if (!email) {
                    showResult("Lütfen e-posta adresinizi girin!", "warning");
                    return;
                }

                var originalHtml = btn.html();
                btn.html('<i class="fas fa-spinner fa-spin mr-2"></i> Gönderiliyor...').prop("disabled", true);

                // Demo amaçlı simülasyon (gerçek API olmadığı için)
                setTimeout(function () {
                    btn.html(originalHtml).prop("disabled", false);
                    showResult("Şifre sıfırlama bağlantısı <strong>" + email + "</strong> adresine gönderildi.", "success");

                    // 3 saniye sonra login sayfasına yönlendir
                    setTimeout(function () {
                        window.location.href = "/login";
                    }, 3000);
                }, 1500);
            });

            function showResult(message, type) {
                $("#divResult")
                    .stop(true, true)
                    .removeClass()
                    .addClass("alert alert-" + type)
                    .html('<i class="fas fa-info-circle mr-2"></i>' + message)
                    .fadeIn(300);
            }
        });
    </script>
}