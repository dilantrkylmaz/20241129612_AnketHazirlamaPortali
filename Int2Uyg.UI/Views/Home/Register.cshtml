@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Anket Portalı - Kayıt Ol</title>

    <link href="~/sbadmin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="~/sbadmin/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body class="bg-gradient-primary">
    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-register-image" style="background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800'); background-size: cover; background-position: center;"></div>

                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4 font-weight-bold">Yeni Hesap Oluştur!</h1>
                                <p class="text-muted small mb-4">Anketlere katılmak ve dünyayı şekillendirmek için hemen üye ol.</p>
                            </div>

                            <form class="user" id="frmRegister">
                                <div class="form-group">
                                    <input type="text" class="form-control form-control-user" id="txtFullName" placeholder="Adınız Soyadınız">
                                </div>
                                <div class="form-group">
                                    <input type="text" class="form-control form-control-user" id="txtUserName" placeholder="Kullanıcı Adı">
                                </div>
                                <div class="form-group">
                                    <input type="email" class="form-control form-control-user" id="txtEmail" placeholder="E-Posta Adresi">
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <input type="password" class="form-control form-control-user" id="txtPassword" placeholder="Şifre">
                                    </div>
                                    <div class="col-sm-6">
                                        <input type="password" class="form-control form-control-user" id="txtPasswordConfirm" placeholder="Şifre Tekrar">
                                    </div>
                                </div>

                                <button type="button" id="btnRegister" class="btn btn-primary btn-user btn-block font-weight-bold shadow-sm">
                                    Hesabı Oluştur
                                </button>
                            </form>

                            <hr>
                            <div id="divResult" class="mt-3 text-center" style="display:none; border-radius: 20px;"></div>

                            <div class="text-center mt-3">
                                <a class="small font-weight-bold text-primary" href="/Login">Zaten bir hesabın var mı? Giriş Yap!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/sbadmin/vendor/jquery/jquery.min.js"></script>
    <script src="~/sbadmin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // API Adresi (Hatasız bağlantı için Layout ile aynı)
            var apiBaseUrl = "https://localhost:7258/api";

            $("#btnRegister").click(function () {
                var fullName = $("#txtFullName").val();
                var userName = $("#txtUserName").val();
                var email = $("#txtEmail").val();
                var password = $("#txtPassword").val();
                var confirmPassword = $("#txtPasswordConfirm").val();

                // Boşluk Kontrolü
                if (!fullName || !userName || !email || !password) {
                    showResult("Lütfen tüm alanları doldurunuz!", "warning");
                    return;
                }

                // Şifre Uyuşmazlığı
                if (password !== confirmPassword) {
                    showResult("Şifreler birbiriyle uyuşmuyor!", "danger");
                    return;
                }

                // Cinsiyetsiz, Tertemiz Kayıt Paketi
                var registerData = {
                    FullName: fullName.trim(),
                    UserName: userName.trim(),
                    Email: email.trim(),
                    Password: password
                };

                var btn = $(this);
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> İşleniyor...');

                // API'ye İstek Atıyoruz
                $.ajax({
                    url: apiBaseUrl + "/User/Add",
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(registerData),
                    success: function (d) {
                        if (d.status || d.Status) {
                            showResult("Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz...", "success");
                            setTimeout(function () { window.location.href = "/Login"; }, 2000);
                        } else {
                            showResult(d.message || d.Message, "danger");
                            btn.prop("disabled", false).text("Hesabı Oluştur");
                        }
                    },
                    error: function () {
                        showResult("Sunucu bağlantı hatası! Lütfen API'yi kontrol edin.", "danger");
                        btn.prop("disabled", false).text("Hesabı Oluştur");
                    }
                });
            });

            // Gelişmiş Sonuç Gösterme Fonksiyonu
            function showResult(m, t) {
                $("#divResult")
                    .stop(true, true)
                    .hide()
                    .removeClass()
                    .addClass("alert alert-" + t + " p-2")
                    .html('<i class="fas fa-info-circle mr-1"></i> ' + m)
                    .fadeIn();
            }
        });
    </script>
</body>
</html>